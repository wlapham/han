{
  "name": "example-marketplace",
  "description": "An example marketplace demonstrating all available marketplace.json fields",
  "version": "1.0.0",
  "owner": {
    "name": "Your Name",
    "email": "you@example.com"
  },
  "metadata": {
    "pluginRoot": "./plugins",
    "description": "Alternate description location (merged with root description)",
    "version": "1.0.0"
  },
  "allowCrossMarketplaceDependenciesOn": ["other-internal-marketplace", "partner-tools-marketplace"],
  "plugins": [
    {
      "name": "relative-path-plugin",
      "displayName": "Relative Path Plugin",
      "source": "./relative-path-plugin",
      "description": "A plugin loaded from a relative path within this repository",
      "version": "1.2.0",
      "defaultEnabled": true,
      "author": {
        "name": "Your Name",
        "email": "you@example.com"
      },
      "homepage": "https://github.com/your-org/your-plugin",
      "repository": "https://github.com/your-org/your-plugin",
      "license": "MIT",
      "keywords": ["example", "relative"],
      "category": "productivity",
      "tags": ["reference", "template"],
      "strict": true,
      "skills": "./skills/",
      "commands": "./commands/",
      "agents": "./agents/",
      "hooks": "./hooks/hooks.json",
      "mcpServers": {
        "example-server": {
          "command": "${CLAUDE_PLUGIN_ROOT}/servers/example-server",
          "args": ["--config", "${CLAUDE_PLUGIN_ROOT}/config.json"]
        }
      },
      "lspServers": "./.lsp.json"
    },
    {
      "name": "github-plugin",
      "source": {
        "source": "github",
        "repo": "your-org/example-claude-plugin",
        "ref": "v2.0.0",
        "sha": "a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2"
      },
      "description": "A plugin loaded from a GitHub repository at a pinned tag and SHA",
      "version": "2.0.0",
      "author": {
        "name": "Your Name",
        "email": "you@example.com"
      },
      "homepage": "https://github.com/your-org/example-claude-plugin",
      "repository": "https://github.com/your-org/example-claude-plugin",
      "license": "Apache-2.0",
      "keywords": ["github", "example"],
      "category": "developer-tools",
      "tags": ["ci", "automation"],
      "strict": true
    },
    {
      "name": "url-plugin",
      "source": {
        "source": "url",
        "url": "https://gitlab.com/example-org/claude-plugin.git",
        "ref": "main",
        "sha": "b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3"
      },
      "description": "A plugin loaded from a non-GitHub git host",
      "version": "0.9.0",
      "author": {
        "name": "Example Org",
        "email": "team@example-org.com"
      },
      "homepage": "https://gitlab.com/example-org/claude-plugin",
      "repository": "https://gitlab.com/example-org/claude-plugin",
      "license": "MIT",
      "keywords": ["gitlab", "url-source"],
      "category": "utilities",
      "tags": ["external"],
      "strict": false
    },
    {
      "name": "monorepo-plugin",
      "source": {
        "source": "git-subdir",
        "url": "https://github.com/your-org/internal-monorepo.git",
        "path": "tools/claude-plugin",
        "ref": "v1.5.0",
        "sha": "c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4"
      },
      "description": "A plugin sourced from a subdirectory of a monorepo using sparse checkout",
      "version": "1.5.0",
      "author": {
        "name": "Your Name",
        "email": "you@example.com"
      },
      "homepage": "https://github.com/your-org/internal-monorepo",
      "repository": "https://github.com/your-org/internal-monorepo",
      "license": "MIT",
      "keywords": ["monorepo", "git-subdir"],
      "category": "internal",
      "tags": ["sparse-checkout"],
      "strict": true
    },
    {
      "name": "npm-plugin",
      "source": {
        "source": "npm",
        "package": "@your-scope/claude-plugin-example",
        "version": "^3.0.0",
        "registry": "https://registry.npmjs.org"
      },
      "description": "A plugin distributed as an npm package with a semver range",
      "version": "3.1.0",
      "author": {
        "name": "Your Name",
        "email": "you@example.com"
      },
      "homepage": "https://www.npmjs.com/package/@your-scope/claude-plugin-example",
      "repository": "https://github.com/your-org/claude-plugin-example",
      "license": "MIT",
      "keywords": ["npm", "package"],
      "category": "developer-tools",
      "tags": ["published"],
      "strict": true
    }
  ]
}
